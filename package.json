{
  "name": "writing-detector",
  "version": "1.0.0",
  "private": true,
  "author": "Ankur Singh <hello@anks.in>",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@sveltejs/adapter-cloudflare": "^7.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "sass": "^1.77.8",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "type": "module",
  "overrides": {
    "sass-embedded": "npm:sass@^1.77.8"
  },
  "dependencies": {
    "marked": "^17.0.5"
  }
}
