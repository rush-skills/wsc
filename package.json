    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "sass-embedded": "^1.85.1",
    "svelte": "^4.2.7",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.3",
    "vitest": "^3.2.4"
  },
  "type": "module"
}
